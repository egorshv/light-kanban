# Скопируйте в .env (docker compose подхватит автоматически) и заполните.

# --- Обязательно ---
# Секрет подписи JWT (HS256). Сгенерировать: openssl rand -hex 32
KANBAN_JWT_SECRET=0360b9fdf6b6badfca9332634e172a56cb24babbe1f175e76b770c124e2697cd

# --- Опционально ---
# Срок жизни токена, секунд (по умолчанию 24 часа)
#KANBAN_JWT_TTL=86400

# Вход через Google: OAuth-клиент типа «Web application» из
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {origin}/api/v1/auth/google/callback
# Пусто ⇒ вход через Google отключён.
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
# Нужен, только если origin за reverse-proxy не определяется сам
#GOOGLE_REDIRECT_URI=

# Путь к файлу SQLite (в docker задан в compose: /data/kanban.db)
#KANBAN_DB_PATH=kanban.db

# Уровень структурных JSON-логов
#KANBAN_LOG_LEVEL=INFO

# Каталог собранной SPA (по умолчанию frontend/dist)
#KANBAN_STATIC_DIR=
